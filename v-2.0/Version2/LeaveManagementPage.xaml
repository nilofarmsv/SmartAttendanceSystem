<Page x:Class="WorkSanse.LeaveManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WorkSanse.Healpers"
      xmlns:vm="clr-namespace:WorkSanse.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      FlowDirection="RightToLeft"
      Background="#f5f5f5"
      Title="مدیریت مرخصی">
    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:PersianDateTimeConverter x:Key="PersianDateTimeConverter"/>

        <Style x:Key="DarkBlueDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#062A36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="RowBackground" Value="#062A36"/>
            <Setter Property="AlternatingRowBackground" Value="#083544"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="BorderBrush" Value="#0A3C4F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <!-- Column Header Style -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#083544"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#0A3C4F"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>

        </Style>

        <!-- Row Style -->
        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0A3C4F"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0F4C64"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cell Style -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <!-- Style کلی برای همه دکمه ها -->
        <Style x:Key="HoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00A99D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Content" Value="پیشفرض دکمه"/>
            <!-- متن اصلی -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Trigger برای MouseOver -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00B4CC"/>
                                <Setter Property="Foreground" Value="#0000FF"/>
                                <Setter Property="Content" Value="هاور فعال"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Grid.Column="1">

        <ScrollViewer>
            <StackPanel Margin="20">

                <!-- فیلترها -->
                <StackPanel Orientation="Horizontal" Margin="0 0 0 20" >

                    <!-- انتخاب تاریخ -->
                   
                    <!-- جستجو -->
                    <TextBlock Text="جستجو" VerticalAlignment="Center" Margin="0 0 5 0"/>
                    <wpfui:TextBox Name="Family" PlaceholderText="جستجو نام کاربر..." Width="180" Height="38"
                                   Text="{Binding SearchUserName,UpdateSourceTrigger=PropertyChanged}" Background="Gray"/>


                </StackPanel>

                <!-- جدول درخواست های مرخصی -->
                <DataGrid x:Name="LeaveManagementDataGrid" ItemsSource="{Binding ManageLeaveViewModel}" AutoGenerateColumns="False" SelectedItem="{Binding SelectedLeave}" CanUserAddRows="False" Height="350" Width="727"  Style="{StaticResource DarkBlueDataGrid}" Background="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="نام کاربر" Binding="{Binding UserName}" Width="*" />
                        <DataGridTextColumn Header="علت" Binding="{Binding Text}" Width="*" />

                        <DataGridTextColumn Header="تاریخ شروع" Binding="{Binding StartDate, Converter={StaticResource PersianDateTimeConverter}, StringFormat={}{0:yyyy/MM/dd}}" Width="*" />
                        <DataGridTextColumn Header="تاریخ پایان" Binding="{Binding EndDate, Converter={StaticResource PersianDateTimeConverter}, StringFormat={}{0:yyyy/MM/dd}}" Width="*" />
                        <DataGridTextColumn Header="وضعیت" Binding="{Binding Status}" Width="*" />
                        

                        <!-- دکمه‌های عملیات -->
                        <DataGridTemplateColumn Header="عملیات" Width="170"  >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" >

                                        <Button Content="تایید" Width="70" Height="30"
                                                Style="{StaticResource HoverButtonStyle}"  Click="ApproveLeave_Click"/>

                                        <Button Content="رد" Width="70" Height="30"
                                                Style="{StaticResource HoverButtonStyle}" Click="RejectLeave_Click" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

                <!-- نوتیفیکیشن -->
                <Border Background="#00A99D" CornerRadius="8" Padding="10" Margin="0 20 0 0" Visibility="Collapsed">
                    <TextBlock Text="پیام تایید یا رد ارسال شد." Foreground="White"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>

</Page>
