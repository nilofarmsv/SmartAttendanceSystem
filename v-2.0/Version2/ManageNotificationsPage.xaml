<Page x:Class="WorkSanse.ManageNotificationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WorkSanse.Healpers"
      
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      FlowDirection="RightToLeft"
      Background="#f5f5f5"
      Title="مدیریت اعلان‌ها">


    <Page.Resources>
    
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:PersianDateTimeConverter x:Key="PersianDateTimeConverter"/>







        <Style x:Key="DarkBlueDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#062A36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="RowBackground" Value="#062A36"/>
            <Setter Property="AlternatingRowBackground" Value="#083544"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="BorderBrush" Value="#0A3C4F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <!-- Column Header Style -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#083544"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#0A3C4F"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <!-- Row Style -->
        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0A3C4F"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0F4C64"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cell Style -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    
    <Style x:Key="HoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00A99D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                      Background="{TemplateBinding Background}"
                      CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00C4B4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
            
        
    </Page.Resources>


    <Grid Grid.Column="1">
        <ScrollViewer>
            <StackPanel Margin="20">

                <!-- عنوان -->
                <TextBlock Text="مدیریت اعلان‌ها"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0 0 0 20"/>

                <!-- فیلترها -->
               

                <!-- دکمه‌های عملیات -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 0 0 20" >
                    <Button Content="ارسال دستی" Width="120" Height="35" Style="{StaticResource HoverButtonStyle}" Click="OpenSendModal_Click"/>
                   
                </StackPanel>

                <!-- جدول نمایش اعلان‌ها -->
                <DataGrid x:Name="NotificationsDataGrid" AutoGenerateColumns="False" Style="{StaticResource DarkBlueDataGrid}" Background="White" Width="706" Height="234">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="متن پیام" Binding="{Binding Message}" Width="*"/>
                        <DataGridTextColumn Header="وضعیت ارسال" Binding="{Binding Status}" Width="130"/>
                        <DataGridTextColumn Header="تاریخ" Binding="{Binding Date, Converter={StaticResource PersianDateTimeConverter}}" Width="140"/>

                       

                        <!-- ارسال -->
                        <DataGridTemplateColumn Header="ارسال" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="ارسال"
                                            Width="90"
                                            Height="30"
                                            Click="SendNotification_Click"                                            Style="{StaticResource HoverButtonStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- حذف -->
                        <DataGridTemplateColumn Header="حذف" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="حذف"
                                            Width="90"
                                            Height="30"
                                            Style="{StaticResource HoverButtonStyle}"
                                            Click="DeleteNotificationButton_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>

            </StackPanel>
        </ScrollViewer>
        <Grid
    Background="#80000000"
    Visibility="{Binding IsSendModalOpen, Converter={StaticResource BoolToVisibilityConverter}}"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

            <Border
        Background="White"
        CornerRadius="10"
        Padding="30"
        Width="360"
        HorizontalAlignment="Center"
        VerticalAlignment="Center">

                <StackPanel>

                    <TextBlock
                Text="ارسال اعلان"
                FontSize="18"
                FontWeight="Bold"
                Margin="0 0 0 15"/>

                    <TextBox
                        
                        Background="AliceBlue"
                        x:Name="txtNotification"
                Height="100"
                TextWrapping="Wrap"
                AcceptsReturn="True"
                Text="{Binding NotificationText, UpdateSourceTrigger=PropertyChanged}"
                
                Margin="0 0 0 20"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                        <Button
                            Background="AntiqueWhite"
                            Foreground="Black"
                    Content="لغو"
                    Width="80"
                    Margin="0 0 10 0"
                    Click="CancelSend_Click"/>

                        <Button
                    Content="ارسال"
                    Width="80"
                    Style="{StaticResource HoverButtonStyle}"
                    Click="ConfirmSend_Click"/>

                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

</Page>
