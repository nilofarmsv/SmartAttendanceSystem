<Window x:Class="WorkSanse.Rigister"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Register"
        Width="650" Height="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F2F4F7"
        WindowStyle="None">

    <Window.Resources>
        
        <!-- HoverButtonStyle -->
        <Style x:Key="HoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00A99D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00C4B4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="White"
                CornerRadius="14"
                Padding="30"
                Width="690"
                Height="700"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <!-- ستون فیلدها سمت چپ -->
                    <ColumnDefinition Width="240"/>
                    <!-- ستون عکس سمت راست -->
                </Grid.ColumnDefinitions>

                <!-- ستون چپ: ورودی‌ها -->
                <StackPanel Grid.Column="0"
                            Margin="20,0,30,0"
                            VerticalAlignment="Center"
                            FlowDirection="RightToLeft" Height="576">
                    <TextBlock Text="فرم ثبت‌نام کاربر"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#222"
                               HorizontalAlignment="Center"
                               Margin="0 0 0 15"/>

                    <wpfui:TextBox Name="Name" PlaceholderText="نام" Height="42" Margin="0 0 0 12"/>
                    <wpfui:TextBox Name="Family" PlaceholderText="نام خانوادگی" Height="42" Margin="0 0 0 12"/>
                    <wpfui:TextBox Name="NationalCode" PlaceholderText="کد ملی" Height="42" Margin="0 0 0 12"/>
                    <wpfui:TextBox Name="Phone" PlaceholderText="شماره تلفن" Height="42" Margin="0 0 0 12"/>
                    <wpfui:TextBox Name="UserName" PlaceholderText="نام کاربری" Height="42" Margin="0 0 0 12"/>

                    <wpfui:PasswordBox Name="Password" PasswordChanged="Password_PasswordChanged" PlaceholderText="رمز عبور" Height="42" Margin="0 0 0 0"/>
                    <ProgressBar x:Name="PasswordStrengthBar" Height="14" Margin="0,0,0,5" Maximum="100"/>
                    <wpfui:PasswordBox Name="RePassword" PlaceholderText="تکرار رمز عبور" Height="42" Margin="0 0 0 10"/>

                    <Border BorderBrush="#777" BorderThickness="1"
                            CornerRadius="10" Padding="12" Margin="0 0 0 20" Height="83">
                        <StackPanel>
                            <TextBlock x:Name="Role" Text="سمت"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="#333"
                                       Margin="0 0 0 8"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="315">
                                <RadioButton x:Name="Manegement" Content="مدیر" Tag="Manegement" GroupName="roles" FontSize="14" Foreground="#333"/>
                                <RadioButton x:Name="Admin" Content="ادمین" Tag="Admin" GroupName="roles" FontSize="14" Foreground="#333"/>
                                <RadioButton x:Name="Emploee" Content="کارمند" Tag="Emploee" GroupName="roles" FontSize="14" Foreground="#333" Width="79"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Content="ثبت نام"
                            Width="200"
                            Height="45"
                            HorizontalAlignment="Center"
                            Style="{StaticResource HoverButtonStyle}"
                            Click="RegisterUser_Click"/>
                </StackPanel>

                <!-- ستون راست: عکس + دکمه آپلود -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Width="220"
                            FlowDirection="LeftToRight">
                    <Border Width="160" Height="160"
                            Background="#E8EBF0"
                            CornerRadius="80"
                            Margin="0 0 0 15"
                            ClipToBounds="True">
                        <Image x:Name="ProfileImage" Stretch="UniformToFill"/>
                    </Border>

                    <Button Content="آپلود عکس"
                            Width="160"
                            Height="40"
                            Style="{StaticResource HoverButtonStyle}"
                            Click="UploadPhoto_Click"/>
                    <TextBlock Text="بازگشت"
Foreground="#00A99D"
HorizontalAlignment="Center"
Margin="0 15 0 0"
Cursor="Hand"
FontWeight="SemiBold"
MouseLeftButtonDown="Back_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
