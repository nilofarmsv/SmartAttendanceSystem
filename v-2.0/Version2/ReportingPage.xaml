<Page x:Class="WorkSanse.ReportingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WorkSanse"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      FlowDirection="RightToLeft"
      Background="#f5f5f5"
      Title="گزارش‌ها و نمودارها">

    <Page.Resources>

        <Style x:Key="HoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00A99D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                      Background="{TemplateBinding Background}"
                      CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00C4B4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>


    <Grid Grid.Column="1">
        <ScrollViewer>
            <StackPanel Margin="20" >

                <!-- عنوان -->

                <!-- محدوده تاریخ -->
                <StackPanel Orientation="Horizontal" >
                    <StackPanel>
                        <TextBlock Text="از تاریخ:" Margin="0 0 0 5"/>
                        <DatePicker Width="200"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="تا تاریخ:" Margin="0 0 0 5"/>
                        <DatePicker Width="200"/>
                    </StackPanel>
                </StackPanel>

                <!-- انتخاب نوع گزارش -->
                <StackPanel Orientation="Horizontal" >
                    <ComboBox Width="200">
                        <ComboBoxItem Content="روزانه"/>
                        <ComboBoxItem Content="هفتگی"/>
                        <ComboBoxItem Content="ماهانه"/>
                    </ComboBox>

                    <ComboBox Width="200">
                        <ComboBoxItem Content="گزارش حضور و غیاب"/>
                        <ComboBoxItem Content="گزارش مرخصی‌ها"/>
                        <ComboBoxItem Content="گزارش کاربران"/>
                    </ComboBox>
                </StackPanel>

                <!-- فیلترهای اضافی -->
                <StackPanel Orientation="Horizontal" >

                    <ComboBox Width="200" >
                        <ComboBoxItem Content="همه"/>
                        <ComboBoxItem Content="استحقاقی"/>
                        <ComboBoxItem Content="استعلاجی"/>
                        <ComboBoxItem Content="ساعتی"/>
                    </ComboBox>

                    <ComboBox Width="200" >
                        <ComboBoxItem Content="همه کاربران"/>
                    </ComboBox>

                </StackPanel>

                <!-- نمودارها -->
                <Border Background="White"
                        Height="250"
                        CornerRadius="10"
                        Padding="10"
                        BorderBrush="#DDD"
                        BorderThickness="1">
                    <TextBlock Text="(محل نمایش نمودار)"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"
                               Foreground="#777"/>
                </Border>

                <!-- Export Buttons -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            >

                    <Button Content="Export Excel"
                            Width="140"
                            Height="40"
                            Style="{StaticResource HoverButtonStyle}"/>

                    <Button Content="Export PDF"
                            Width="140"
                            Height="40"
                            Style="{StaticResource HoverButtonStyle}"/>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</Page>
