<Page x:Class="WorkSanse.NotificationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      
      xmlns:local="clr-namespace:WorkSanse.Healpers"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      FlowDirection="RightToLeft"
      Background="#f5f5f5"
      Title="نوتیفیکیشن‌ها">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:PersianDateTimeConverter x:Key="PersianDateTimeConverter"/>
        
        <Style x:Key="DarkBlueDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="#062A36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="RowBackground" Value="#062A36"/>
            <Setter Property="AlternatingRowBackground" Value="#083544"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="BorderBrush" Value="#0A3C4F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
        </Style>

        <!-- Column Header Style -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#083544"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#0A3C4F"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            
        </Style>

        <!-- Row Style -->
        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0A3C4F"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0F4C64"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Cell Style -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <!-- همان استایل دکمه ها -->
        <Style x:Key="HoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00A99D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00B4CC"/>
                                <Setter Property="Foreground" Value="#0000FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">

        <StackPanel>

            <!-- عنوان صفحه -->
            <TextBlock Text="نوتیفیکیشن‌های دریافتی از مدیر" 
                       FontSize="20" FontWeight="Bold" Foreground="#062A36"
                       HorizontalAlignment="Center" Margin="0 0 0 20"/>

            <!-- لیست نوتیفیکیشن ها -->
            <DataGrid x:Name="SendNotificationsDataGrid" AutoGenerateColumns="False" Style="{StaticResource DarkBlueDataGrid}" Background="White" Height="300" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="فرستنده" Binding="{Binding Role}" Width="*" />
                    <DataGridTextColumn Header="پیام" Binding="{Binding Message}" Width="2*"/>
                    <DataGridTextColumn Header="تاریخ ارسال" Binding="{Binding Date, Converter={StaticResource PersianDateTimeConverter}}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- دکمه ریفرش برای بروزرسانی نوتیفیکیشن‌ها -->
            <Button Content="بروزرسانی" Width="150" Height="40" 
                    HorizontalAlignment="Center" Margin="0 20 0 0"
                    Style="{StaticResource HoverButtonStyle}"
                    Click="Update_Click"/>

        </StackPanel>

    </Grid>
</Page>
