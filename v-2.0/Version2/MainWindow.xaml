<Window x:Class="WorkSanse.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WorkSanse.ViewModels"
        xmlns:local="clr-namespace:WorkSanse"
        mc:Ignorable="d"
        Title="WorkSence" Height="581" Width="987">
    <Window.DataContext>
        <vm:DataViewModel></vm:DataViewModel>
    </Window.DataContext>
    <Grid FlowDirection="RightToLeft">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <!-- Sidebar -->
            <ColumnDefinition Width="35*"/>
            <ColumnDefinition Width="214*"/>
            <!-- Main Content -->
        </Grid.ColumnDefinitions>

        <!-- Sidebar (Right Side) -->
        <Border Background="#062A36" Grid.Column="0">
            <StackPanel Margin="20">

                <!-- Logo -->
                <TextBlock Text="WorkSense"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0 20 0 40"
                       TextAlignment="Center"/>

                <!-- Profile area -->
                <Border Width="100" Height="100"
                       Background="#E8EBF0"
                       CornerRadius="80"
                       Margin="0 0 0 15"
                       ClipToBounds="True">
                    <Image x:Name="ProfileImage" Stretch="UniformToFill"/>
                </Border>
                <TextBlock x:Name="welcome" Text="" Foreground="White" FontSize="16"
                       HorizontalAlignment="Center" Margin="0 10 0 0"/>
                <TextBlock x:Name="role" Text="" Foreground="#dddddd"
                       FontSize="12" HorizontalAlignment="Center"/>

                <!-- Menu items -->
                <StackPanel>
                    <Border Background="#00B4A2" CornerRadius="6" Padding="10" Margin="0 0 0 10">
                        <TextBlock Text="داشبورد" Foreground="White" MouseDown="DashboardMenu_Click"/>
                    </Border>
                    <Button Content="مدیریت کاربران"  Click="UserMenu_Click" Background="Transparent" BorderThickness="0" Foreground="#b0c4cc"  Padding="0" Margin="0 0 0 10" Cursor="Hand"/>
                    <Button Content="مدیریت اعلان ها"  Click="NotificationsMenu_Click" Background="Transparent" BorderThickness="0" Foreground="#b0c4cc"  Padding="0" Margin="0 0 0 10" Cursor="Hand"/>
                    <Button Content="مدیریت حضور و غیاب"  Click="AttendanceMenu_Click" Background="Transparent" BorderThickness="0" Foreground="#b0c4cc"  Padding="0" Margin="0 0 0 10" Cursor="Hand"/>
                    <Button Content="مدیریت مرخصی"  Click="LeaveMenu_Click" Background="Transparent" BorderThickness="0" Foreground="#b0c4cc"  Padding="0" Margin="0 0 0 10" Cursor="Hand"/>
                    <Button Content="خروج"  Click="ExitMenu_Click" Background="Transparent" BorderThickness="0" Foreground="#b0c4cc"  Padding="0" Margin="0 0 0 10" Cursor="Hand"/>

                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Main Content (Left Side) -->
        <Grid Grid.Column="1" FlowDirection="RightToLeft" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Background="#00A99D" Grid.Row="0">
                <Grid Margin="10">
                    <TextBlock Text="{Binding PersianDateTime}"
                           Foreground="White" FontSize="18"
                           VerticalAlignment="Center"
                           TextAlignment="Right"/>
                    

                    <!-- Icons -->
                    <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left">
                        <TextBlock Text="🔔" FontSize="20" Margin="10 0" MouseLeftButtonDown="Notifications_Click"/>

                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <!-- Frame for dynamic content -->
            <Frame Name="MainFrame" Grid.Row="1" NavigationUIVisibility="Hidden" Navigated="MainFrame_Navigated"/>

        </Grid>
    </Grid>

</Window>
