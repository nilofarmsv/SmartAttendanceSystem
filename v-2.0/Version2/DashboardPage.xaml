<Page x:Class="WorkSanse.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
      xmlns:local="clr-namespace:WorkSanse"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      FlowDirection="RightToLeft"
      Background="#f5f5f5"
      Title="داشبورد">

    <Page.Resources>
        <!-- Style کلی برای همه دکمه ها -->
        <Style x:Key="HoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00A99D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <!-- متن اصلی -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Trigger برای MouseOver -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#062A36"/>
                                <Setter Property="Foreground" Value="#062A36"/>
                                <Setter Property="Content" Value="هاور فعال"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>




    <Grid Grid.Column="1">

        <!-- Content -->
        <ScrollViewer>

            <StackPanel Margin="20" >

                <!-- سه کارت آماری -->
                <UniformGrid Columns="3" Margin="0 0 0 10" HorizontalAlignment="Stretch" Height="108">

                    <!-- کارت ۱ -->
                    <StackPanel Background="White"  Margin="10" >
                        <TextBlock x:Name="currentEmploee" Text="{Binding PresentCount}" FontSize="36" FontWeight="SemiBold" Foreground="#333"/>
                        <TextBlock  Text="کارکنان حاضر" Foreground="#999"/>
                        <Border Background="#00B4A2" Height="4" Width="40" Margin="0 5"/>
                    </StackPanel>

                    <!-- کارت ۲ -->
                    <StackPanel Background="White"  Margin="10">
                        <TextBlock x:Name="absentEmploee" Text="{Binding AbsentCount}" FontSize="36" FontWeight="SemiBold" Foreground="#333"/>
                        <TextBlock Text="کارکنان غایب" Foreground="#999"/>
                        <Border Background="#FF6B6B" Height="4" Width="40" Margin="0 5"/>
                    </StackPanel>

                    <!-- کارت ۳ -->
                    <StackPanel Background="White"  Margin="10">
                        <TextBlock x:Name="LeaveRequest" Text="{Binding PendingLeaveCount}" FontSize="36" FontWeight="SemiBold" Foreground="#333"/>
                        <TextBlock Text="درخواست های مرخصی" Foreground="#999"/>
                        <Border Background="#FFA500" Height="4" Width="40" Margin="0 5"/>
                    </StackPanel>

                </UniformGrid>

                <!-- دکمه -->
                <Button Content="ثبت دستی ورود  /  خروج"
                    Background="#00A99D"
                    Foreground="White"
                    Padding="5"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    BorderThickness="0"
                    Width="250"
                    Style="{StaticResource HoverButtonStyle}" Height="29"
                    />

                <!-- نمودار Placeholder -->
                <StackPanel>
                    <TextBlock Text="نمودار حضور و غیاب هفته جاری" FontWeight="Bold" Margin="0 5 0 0"/>
                    <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,0,0,0">

                        <Button Content="⏮ هفته قبل"
            Command="{Binding PrevWeekCommand}"
            Margin="5" Background="#00A99D"
 Foreground="White"
 Padding="5"
 FontWeight="Bold"
 BorderThickness="0"
 Width="100"
 Style="{StaticResource HoverButtonStyle}" Height="29"/>

                        <Button Content="هفته بعد ⏭"
            Command="{Binding NextWeekCommand}"
            Margin="5"  Background="#00A99D"
 Foreground="White"
 Padding="5"
 FontWeight="Bold"
 BorderThickness="0"
 Width="96"
 Style="{StaticResource HoverButtonStyle}" Height="29"/>
                    </StackPanel>


                    <Border Background="#ddd" Height="200" CornerRadius="10">
                        <lvc:CartesianChart Series="{Binding SeriesCollection}">

                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Labels="{Binding WeekDays}" />
                            </lvc:CartesianChart.AxisX>

                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="تعداد افراد حاضر" />
                            </lvc:CartesianChart.AxisY>

                        </lvc:CartesianChart>

                    </Border>
                </StackPanel>

            </StackPanel>

        </ScrollViewer>

    </Grid>




</Page>
