<Window x:Class="WorkSanse.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpfui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Login"
        Width="380" Height="480"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F2F4F7"
        WindowStyle="None">
    <Window.Resources>

        <Style x:Key="HoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00A99D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                      Background="{TemplateBinding Background}"
                      CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00C4B4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- کارت سفید مرکزی -->
        <Border Background="White"
                CornerRadius="14"
                Padding="30"
                Width="330"
                Height="433"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                >

            <StackPanel>

                <!-- عنوان -->
                <TextBlock Text="ورود به سیستم "
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#222"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 25"/>

                <!-- تکست باکس نام کاربری -->
                <wpfui:TextBox x:Name="UsernameTextBox"
                               PlaceholderText="نام کاربری"
                               Margin="0 0 0 15"
                               TextAlignment="Right"
                               Height="42"/>

                <!-- پسوورد -->
                <wpfui:PasswordBox x:Name="PasswordBox"
                                   PlaceholderText="رمز عبور"
                                   Margin="0 0 0 15"
                                   TextAlignment="Right"
                                   Height="42"/>

                <!-- مرا به خاطر بسپار -->
                <CheckBox x:Name="RememberMeCheckBox"
                          Content="مرا به خاطر بسپار"
                          Foreground="#444"
                          HorizontalAlignment="Right"
                          Margin="0 0 0 15"/>

                <!-- دکمه ورود -->
                <wpfui:Button x:Name="LoginButton"
                              Content="ورود"
                             
                              Height="45"
                              HorizontalAlignment="Center"
                              CornerRadius="10"
                              FontWeight="SemiBold"
                              Style="{StaticResource HoverButtonStyle}"
                              Margin="0 10 0 0" Width="199" Click="LoginButton_Click"/>

                <!-- فراموشی رمز عبور -->
                <TextBlock Text="ثبت نام نکردی؟ کلیک کن"
                           Foreground="#00A99D"
                           HorizontalAlignment="Center"
                           Margin="0 15 0 0"
                           Cursor="Hand"
                           FontWeight="SemiBold"
                           MouseLeftButtonDown="ForgotPassword_Click"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>
